# .env.example
DATABASE_URL=
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=
# Orígenes permitidos por CORS. Admite una lista separada por comas (sin espacios
# obligatorios) para varios frontends/APIs que consumen el IS. DEBE incluir el
# origen del frontend (tal como lo ve el navegador). En local, el frontend
# corre en http://localhost:3000:
#   ALLOWED_ORIGIN=http://localhost:3000
#   ALLOWED_ORIGIN=https://app.midominio.com,https://admin.midominio.com
ALLOWED_ORIGIN=http://localhost:3000

# Sistema/rol que confiere privilegios de administrador sobre el CRUD de negocio.
# Opcionales (valores por defecto: "auth" / "admin").
ADMIN_SYSTEM_SLUG=auth
ADMIN_ROLE_NAME=admin

# Puerto del servidor HTTP (opcional, por defecto 8080).
PORT=8080

# Nº de proxies de confianza por delante de la API (para calcular la IP real del
# cliente en el rate limiting a partir de X-Forwarded-For). 0 = ignorar XFF y
# usar solo la IP del socket (recomendado si la API se expone directamente).
# Ponlo a 1 si tienes un reverse proxy propio delante, 2 si hay dos, etc.
# EN PRODUCCIÓN detrás de un proxy/balanceador que termina TLS, DEBE ser >= 1:
# con 0, todas las peticiones parecen venir del proxy y comparten un único
# contador de rate limit (un cliente podría bloquear el login de todos).
# TRUST_PROXY_HOPS=1

# Redis para el rate limiting distribuido (compartido entre réplicas). Opcional:
# si se omite, el rate limiter usa un contador en memoria por instancia.
# En docker-compose ya se inyecta automáticamente (servicio `redis`).
# REDIS_URL=redis://localhost:6379
# En producción con contraseña: redis://:TU_PASSWORD@redis:6379
# REDIS_PASSWORD=   # solo la usa docker-compose.prod.yml para levantar Redis

# Entorno de la app. Con APP_ENV=production se DESHABILITA la documentación
# (/api/docs y /api/openapi.json) para no exponer el mapa de la API.
# APP_ENV=production

# Bootstrap del primer admin (solo se usan al ejecutar `bun run db:seed:*`).
# Si el usuario no existe, el seeder lo crea con esta contraseña (debe cumplir
# la longitud mínima de lib/auth.ts) y le asigna el rol admin.
# ADMIN_EMAIL=admin@mercadoelineas.com
# ADMIN_PASSWORD=
# ADMIN_NAME=
