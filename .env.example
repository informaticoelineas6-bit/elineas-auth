# .env.example
DATABASE_URL=
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=
# Orígenes permitidos por CORS. Admite una lista separada por comas (sin espacios
# obligatorios) para varios frontends/APIs que consumen el IS:
#   ALLOWED_ORIGIN=https://app.midominio.com,https://admin.midominio.com
ALLOWED_ORIGIN=

# Sistema/rol que confiere privilegios de administrador sobre el CRUD de negocio.
# Opcionales (valores por defecto: "auth" / "admin").
ADMIN_SYSTEM_SLUG=auth
ADMIN_ROLE_NAME=admin

# Puerto del servidor HTTP (opcional, por defecto 8080).
PORT=8080

# Entorno de la app. Con APP_ENV=production se DESHABILITA la documentación
# (/api/docs y /api/openapi.json) para no exponer el mapa de la API.
# APP_ENV=production

# Bootstrap del primer admin (solo se usan al ejecutar `bun run db:seed:*`).
# Si el usuario no existe, el seeder lo crea con esta contraseña (debe cumplir
# la longitud mínima de lib/auth.ts) y le asigna el rol admin.
# ADMIN_EMAIL=admin@mercadoelineas.com
# ADMIN_PASSWORD=
# ADMIN_NAME=
