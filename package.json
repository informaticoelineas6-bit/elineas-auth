{
  "name": "elineas-auth",
  "type": "module",
  "scripts": {
    "dev": "APP_ENV=local tsx watch src/app.ts",
    "dev:staging": "APP_ENV=staging tsx watch src/app.ts",
    "db:generate:auth:schemas": "npx @better-auth/cli@latest generate --output ./src/db/schema.ts",
    "db:generate:migrations": "npx drizzle-kit generate",
    "db:migrate:local": "APP_ENV=local drizzle-kit migrate",
    "db:migrate:staging": "APP_ENV=staging drizzle-kit migrate",
    "build": "tsc"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.8",
    "@neondatabase/serverless": "^1.1.0",
    "better-auth": "^1.6.23",
    "dotenv": "^17.4.2",
    "drizzle-orm": "1.0.0-rc.4",
    "hono": "^4.12.27",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "1.0.0-rc.4",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3"
  }
}