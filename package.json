{
  "name": "elineas-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:backend": "bun run --filter @elineas/backend dev",
    "dev:frontend": "bun run --filter @elineas/frontend dev",
    "build": "bun run --filter '*' build",
    "typecheck": "bun run --filter '*' typecheck",
    "db:generate:migrations": "bun run --filter @elineas/backend db:generate:migrations",
    "db:migrate:local": "bun run --filter @elineas/backend db:migrate:local",
    "db:seed:local": "bun run --filter @elineas/backend db:seed:local",
    "openapi:generate": "bun run --filter @elineas/backend openapi:generate"
  },
  "trustedDependencies": [
    "esbuild"
  ],
  "devDependencies": {
    "typescript": "^7.0.2"
  }
}
