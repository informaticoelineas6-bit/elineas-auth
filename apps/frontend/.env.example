# --- URLs del backend (se consume como servicio separado) ---

# URL PÚBLICA del backend: la que usa el NAVEGADOR. En Vite se "hornea" en el
# bundle en tiempo de build, así que en Docker se pasa como build-arg.
# En local (sin Docker) el backend corre en :8080.
VITE_BACKEND_URL=http://localhost:8080

# URL INTERNA del backend para el SSR/loaders (que corren en el servidor del
# frontend). En Docker es el nombre del servicio en la red de compose
# (http://backend:8080). Si no se define, el SSR cae a VITE_BACKEND_URL. En
# local (sin Docker) déjala vacía o igual a VITE_BACKEND_URL.
# BACKEND_INTERNAL_URL=http://backend:8080
